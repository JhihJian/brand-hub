/**
 * Environment Variables Example
 * Copy to .env and fill in values for production
 */

# Server
NODE_ENV=development
PORT=3000

# Database
DB_PATH=./data/brand.db

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=https://yourbrand.com/hub
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_AUDIENCES=brand-hub

# SMS Provider (spug)
# Get token and template from Spug platform
SPUG_TOKEN=your-spug-token
SPUG_TEMPLATE_NAME=品牌中心短信验证码

# Development
SMS_MOCK_MODE=true
SMS_MOCK_CODE=123456