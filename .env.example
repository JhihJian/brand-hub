/**
 * Environment Variables Example
 * Copy to .env and fill in values for production
 */

# Server
NODE_ENV=development
PORT=3000

# Database
DB_PATH=./data/brand.db

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=https://yourbrand.com/hub
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# SMS Provider (spug)
SMS_PROVIDER_URL=https://your-sms-provider.com/api/send
SMS_PROVIDER_KEY=your-api-key

# Development
SMS_MOCK_MODE=true
SMS_MOCK_CODE=123456